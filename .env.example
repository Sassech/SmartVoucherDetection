# ============================================================================
# SmartVoucherDetection — variables de entorno
# Copiá este archivo a `.env` y completá con valores reales (.env está en .gitignore).
# ============================================================================

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=smartvoucher
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=smartvoucher
POSTGRES_PORT=5432

# URL completa para SQLAlchemy async (asyncpg).
# Para Alembic en modo sync se deriva en api/alembic/env.py.
DATABASE_URL=postgresql+asyncpg://smartvoucher:changeme_local_only@localhost:5432/smartvoucher

# --- Redis -------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- llama-server (glm-ocr) --------------------------------------------------
# Levantado vía llama.cpp/GLM-OCR.sh
LLAMA_SERVER_URL=http://localhost:8080
# Alias del modelo (matchea el `-a` del script de llama-server).
LLAMA_MODEL_ALIAS=GLM-OCR
# Timeout total por request HTTP (segundos).
LLAMA_TIMEOUT_S=10
# Reintentos ante errores de red o 5xx (NO ante 4xx ni JSON inválido).
LLAMA_MAX_RETRIES=3
